# ROMA-01 Trading Analyzer - Configuration Example
# 复制此文件为 config/roma_config.yaml 并填入你的 API 密钥

system:
  scan_interval_minutes: 3
  prompt_language: "zh"  # zh (中文) 或 en (English)

# DEX 交易账户配置
accounts:
  - id: "aster-acc-01"
    name: "Aster 账户 01"
    dex_type: "aster"
    user: ${ASTER_USER}           # 环境变量
    signer: ${ASTER_SIGNER}        # 环境变量
    private_key: ${ASTER_PRIVATE_KEY}  # 环境变量
    testnet: false
    hedge_mode: false
  
  # 示例：Hyperliquid 账户
  # - id: "hl-acc-01"
  #   name: "Hyperliquid 账户 01"
  #   dex_type: "hyperliquid"
  #   api_secret: ${HL_SECRET_KEY}
  #   account_id: ${HL_ACCOUNT_ADDRESS}
  #   testnet: false
  
  # 示例：Binance 账户
  # - id: "binance-acc-01"
  #   name: "币安账户 01"
  #   dex_type: "binance"
  #   api_key: ${BINANCE_API_KEY}
  #   api_secret: ${BINANCE_API_SECRET}
  #   testnet: false

# LLM 模型配置
models:
  - id: "deepseek-v3.1"
    provider: "deepseek"
    api_key: ${DEEPSEEK_API_KEY}
    model: "deepseek-chat"
    temperature: 0.15
    max_tokens: 4000
  
  - id: "qwen3-max"
    provider: "qwen"
    api_key: ${QWEN_API_KEY}
    model: "qwen-max"
    location: "china"  # "china" 或 "international"
    temperature: 0.15
    max_tokens: 4000
  
  # 示例：Claude
  # - id: "claude-sonnet-4.5"
  #   provider: "anthropic"
  #   api_key: ${ANTHROPIC_API_KEY}
  #   model: "claude-sonnet-4-5-20250929"
  #   temperature: 0.15
  #   max_tokens: 4000
  
  # 示例：GPT
  # - id: "gpt-5"
  #   provider: "openai"
  #   api_key: ${OPENAI_API_KEY}
  #   model: "gpt-4o"
  #   temperature: 0.15
  #   max_tokens: 4000

# 交易分析代理配置
agents:
  - id: "deepseek-aster-01"
    name: "DeepSeek 分析师"
    enabled: true
    account_id: "aster-acc-01"  # 引用上面的账户
    model_id: "deepseek-v3.1"   # 引用上面的模型
    exchange:
      type: "aster"  # 从账户继承
    llm:
      provider: "deepseek"  # 从模型继承
      model: "deepseek-chat"
    strategy:
      # 默认交易对
      default_coins:
        - BTCUSDT
        - ETHUSDT
        - SOLUSDT
        - BNBUSDT
        - DOGEUSDT
        - XRPUSDT
      
      # 风险管理参数
      risk_management:
        max_positions: 3              # 最大同时持仓数
        max_leverage: 10              # 最大杠杆倍数
        max_position_size_pct: 30     # 单笔仓位上限 (%)
        max_total_position_pct: 80    # 总仓位上限 (%)
        max_single_trade_pct: 50      # 无持仓时单笔交易上限 (%)
        max_single_trade_with_positions_pct: 30  # 有持仓时单笔交易上限 (%)
        max_daily_loss_pct: 15        # 每日最大亏损 (%)
        stop_loss_pct: 3              # 自动止损 (%)
        take_profit_pct: 10           # 自动止盈 (%)

# 可选：自定义提示词
# custom_prompts:
#   enabled: false
#   trading_philosophy: "我只交易趋势明确的行情"
#   entry_preferences: "等待 RSI 超卖后金叉入场"
#   position_management: "盈利后移动止损到成本价"
#   market_preferences: "优先交易 BTC 和 ETH"
#   additional_rules: "重大新闻发布前后不交易"
